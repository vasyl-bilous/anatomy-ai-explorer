{
  "name": "anatomy-ai-explorer",
  "engines": {
    "node": ">=22.22.2"
  },
  "version": "0.0.1",
  "description": "Lightweight biomedical research app — explore body regions and generate async AI analysis",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:dev:log": "mkdir -p .dev-logs && nest start --watch 2>&1 | tee .dev-logs/nest-dev.log",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"{src,test,prisma,scripts}/**/*.ts\"",
    "lint:fix": "eslint \"{src,test,prisma,scripts}/**/*.ts\" --fix",
    "format": "prettier \"{src,test,prisma,scripts}/**/*.{ts,js,json,md}\" --write",
    "format:check": "prettier \"{src,test,prisma,scripts}/**/*.{ts,js,json,md}\" --check",
    "knip": "knip",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:reset": "prisma migrate reset",
    "prisma:seed": "tsx src/infrastructure/prisma/seed/seed.ts",
    "prisma:seed:prod": "node dist/infrastructure/prisma/seed/seed.js",
    "db:setup": "prisma migrate deploy && npm run prisma:seed",
    "db:setup:prod": "prisma migrate deploy && npm run prisma:seed:prod",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "eslint --fix --quiet"
    ],
    "*.{mjs,json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@geren32/logger": "^1.0.1",
    "@geren32/nestjs-error-handler": "1.0.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/serve-static": "^5.0.5",
    "@nestjs/swagger": "^11.2.6",
    "@nestjs/terminus": "^11.0.0",
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "compression": "^1.8.1",
    "dotenv": "^17.3.1",
    "helmet": "^8.1.0",
    "pg": "^8.18.0",
    "prisma": "^7.3.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@eslint/js": "^9.22.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/compression": "^1.8.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/supertest": "^6.0.3",
    "eslint": "^9.22.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^16.0.0",
    "husky": "^9.1.7",
    "jest": "^30.0.0",
    "knip": "^5.86.0",
    "lint-staged": "^16.3.3",
    "prettier": "^3.6.2",
    "supertest": "^7.1.3",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.57.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts",
      "tsx"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)sx?$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s",
      "!**/seed/**"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
